generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime = "workerd"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  username String  @unique
  password String
  name     String?
  blogs    Blog[]
}

model Blog {
  id        String  @id @default(uuid())
  title     String
  content   String
  authorId  String
  published Boolean @default(false)
  author    User    @relation(fields: [authorId], references: [id])
}
